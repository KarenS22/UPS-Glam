# Supabase API Settings
# The URL of your Supabase project (e.g., https://xyz.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co
# The Anon/Public Key from your Supabase dashboard
SUPABASE_ANON_KEY=your-supabase-anon-key
# The Service Role Key from your Supabase dashboard (required for admin actions like backend auth management if needed)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# The JWT Secret from your Supabase settings (Settings -> API -> JWT Settings -> JWT Secret)
# VERY IMPORTANT: This is used by the Spring WebFlux backend to verify client-side JWTs locally!
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-minimum-32-characters-long

# Database Connection (R2DBC)
# R2DBC URL format for PostgreSQL (e.g., r2dbc:postgresql://db.xyz.supabase.co:5432/postgres)
SPRING_DATABASE_URL=r2dbc:postgresql://your-supabase-db-host:5432/postgres
SPRING_DATABASE_USERNAME=postgres
SPRING_DATABASE_PASSWORD=your-supabase-db-password

# Application Settings
PORT=8080
CUDA_SERVICE_URL=http://cuda-service:8000
